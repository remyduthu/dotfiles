{
  "permissions": {
    "allow": [
      "Bash(.agents/skills/prod-sql-query/scripts/query-prod.sh *)",
      "Bash(* --help)",
      "Bash(* --version)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(gh * view *)",
      "Bash(gh api */comments *)",
      "Bash(gh pr diff *)",
      "Bash(git * show *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(git fetch *)",
      "Bash(git rebase *)",
      "Bash(git show *)",
      "Bash(git switch *)",
      "Bash(grep *)",
      "Bash(mergify *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(uv *)",
      "Bash(uv run poe test *)",
      "Edit",
      "Read",
      "WebFetch"
    ],
    "ask": [
      "Bash(git push *)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/remyduthu/.config/mergify-cli/claude-hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "i=$(cat); d=$(echo \"$i\" | jq -r '.cwd' | sed \"s|^$HOME|~|\"); t=$(echo \"$i\" | jq -r '.context_window.total_input_tokens // empty'); s=$(echo \"$i\" | jq -r '.context_window.context_window_size // empty'); cs=\"\"; [ -n \"$t\" ] && [ -n \"$s\" ] && u=$(awk -v t=\"$t\" -v s=\"$s\" 'BEGIN{p=(s>0)?t/s*100:0; printf \"%.1fk (%.1f%%)\", t/1000, p}') && cs=$(printf ' · \\033[33m%s\\033[0m' \"$u\"); printf '\\033[36m%s\\033[0m%s\\n' \"$d\" \"$cs\""
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "mergify-internal@mergify-internal": true,
    "skill-creator@claude-plugins-official": true,
    "mattpocock-skills@mattpocock": true
  },
  "extraKnownMarketplaces": {
    "mergify-internal": {
      "source": {
        "source": "directory",
        "path": "/Users/remyduthu/dev/mergify/skills"
      }
    },
    "mattpocock": {
      "source": {
        "source": "github",
        "repo": "mattpocock/skills"
      }
    }
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "disableBypassPermissionsMode": "disable"
}
