{
  "permissions": {
    "allow": [
      "Bash(.agents/skills/prod-sql-query/scripts/query-prod.sh *)",
      "Bash(* --help)",
      "Bash(* --version)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(gh * view *)",
      "Bash(gh api */comments *)",
      "Bash(gh pr diff *)",
      "Bash(git * show *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(git fetch *)",
      "Bash(git rebase *)",
      "Bash(git show *)",
      "Bash(git switch *)",
      "Bash(grep *)",
      "Bash(mergify *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(uv *)",
      "Bash(uv run poe test *)",
      "Edit",
      "Read",
      "WebFetch"
    ],
    "ask": [
      "Bash(git push *)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/remyduthu/.config/mergify-cli/claude-hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "mergify-internal@mergify-internal": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "mergify-internal": {
      "source": {
        "source": "directory",
        "path": "/Users/remyduthu/dev/mergify/skills"
      }
    }
  },
  "statusLine": {
    "type": "command",
    "command": "i=$(cat); d=$(echo \"$i\" | jq -r '.cwd' | sed \"s|^$HOME|~|\"); n=$(echo \"$i\" | jq -r '.session_name // empty'); printf '\\033[36m%s\\033[0m%s\\n' \"$d\" \"${n:+ · $n}\""
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "disableBypassPermissionsMode": "disable"
}
