#!/usr/bin/env bash

# List open pull requests requesting the authenticated user's review.
# Excludes drafts and already-approved PRs. Groups by repository, detects Mergify stacks.

set -euo pipefail

graphql_query="
  query {
    search(query: \"is:open is:pr review-requested:@me draft:false\", type: ISSUE, first: 50) {
      nodes {
        ... on PullRequest {
          number
          title
          url
          baseRefName
          headRefName
          author { login }
          repository { nameWithOwner }
          reviews(author: \"$(gh api user --jq .login)\", last: 1, states: [APPROVED]) {
            totalCount
          }
        }
      }
    }
  }
"

# Build Mergify stack chains and format output as tab-separated lines.
# Stacks are detected by matching each PR's base branch to another PR's head branch.
# Lines without a tab character are repository headers.
# shellcheck disable=SC2016
jq_filter='
  # Follow the Mergify stack chain from a root PR.
  def follow_chain($pulls):
    . as $current
    | [$pulls[] | select(.baseRefName == $current.headRefName)]
    | if length > 0 then .[0], (.[0] | follow_chain($pulls))
      else empty end;

  [.data.search.nodes[] | select(.reviews.totalCount == 0)]
  | group_by(.repository.nameWithOwner)
  | .[]
  | . as $pulls
  | (map(.headRefName)) as $head_branches
  # Root PRs: their base branch is not another PR head branch.
  | [.[] | select(.baseRefName as $base | $head_branches | index($base) | not)] as $roots
  | [$roots[] | [., (. | follow_chain($pulls))]] as $chains
  | ($chains | length) as $chain_count

  | .[0].repository.nameWithOwner,
    ($chains | to_entries[] |
      .key as $chain_index |
      .value |
      ($chain_index == $chain_count - 1) as $is_last_chain |
      to_entries[] |
      .key as $depth | .value |
      (
        if $depth == 0 then
          if $is_last_chain then "└── " else "├── " end
        else
          (if $is_last_chain then "    " else "│   " end)
          + ("    " * ($depth - 1)) + "└── "
        end
      ) as $connector |
      [$connector, (.number | tostring), .title, .url, (.author.login // "unknown")]
      | @tsv
    )
'

gh api graphql --field query="${graphql_query}" \
  | jq --raw-output "${jq_filter}" \
  | while IFS=$'\t' read -r connector number title url author; do
      if [ -z "${number}" ]; then
        # Lines without a tab are repository headers.
        echo "${connector}"
      else
        # OSC 8 hyperlink: make the title clickable in supported terminals.
        printf '    %s\033]8;;%s\033\\#%s %s\033]8;;\033\\ (%s)\n' \
          "${connector}" "${url}" "${number}" "${title}" "${author}"
      fi
    done
