#!/usr/bin/env bash

# List open pull requests requesting the authenticated user's review. Excludes
# drafts, conflicts, already-approved PRs, and PRs with unresolved review
# threads. Groups results by repository.
#
# Usage: gh-reviews [--browse]
#   --browse  Open all listed PRs in the browser.

set -euo pipefail

open_in_browser=false
if [ "${1:-}" = "--browse" ]; then
  open_in_browser=true
fi

# Fetch open PRs requesting the user's review, excluding drafts, conflicts,
# and unresolved review threads. The `reviews` subquery fetches the user's last
# review to filter out already-approved PRs.
search_query='base:main draft:false is:open is:pr -label:conflict -label:"review threads unresolved" review-requested:@me sort:updated-desc'
author_login=$(gh api user --jq .login)

# shellcheck disable=SC2016
graphql_query='
  query($search_query: String!, $author_login: String!) {
    search(query: $search_query, type: ISSUE, first: 50) {
      nodes {
        ... on PullRequest {
          number
          title
          url
          author { login }
          repository { nameWithOwner }
          reviews(author: $author_login, last: 1, states: [APPROVED]) {
            totalCount
          }
        }
      }
    }
  }
'

# Filter out approved PRs, then group by repository.
#
# shellcheck disable=SC2016
jq_filter='
  [.data.search.nodes[] | select(.reviews.totalCount == 0)]
  | group_by(.repository.nameWithOwner)
  | .[]
  | (.[0].repository.nameWithOwner) as $repository
  | $repository,
    (.[] | [(.number | tostring), .title, .url, (.author.login // "unknown")] | @tsv)
'

api_response=$(gh api graphql --field query="${graphql_query}" --field search_query="${search_query}" --field author_login="${author_login}" | jq --raw-output "${jq_filter}")

if [ -z "${api_response}" ]; then
  echo "Nothing to review"
  exit 0
fi

while IFS=$'\t' read -r number title url author; do
  if [ -z "${title}" ]; then
    # Lines without a tab are repository headers.
    echo "${number}"
  else
    # OSC 8 hyperlink: make the title clickable in supported terminals.
    # Format: ESC]8;;<url>ESC\<text>ESC]8;;ESC\
    printf '  • \033]8;;%s\033\\#%s %s\033]8;;\033\\ by %s\n' \
      "${url}" "${number}" "${title}" "${author}"

    if [ "${open_in_browser}" = true ]; then
      open "${url}"
    fi
  fi
done <<< "${api_response}"
