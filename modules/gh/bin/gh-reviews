#!/usr/bin/env bash

# List open pull requests requesting the authenticated user's review. Excludes
# drafts, already-approved PRs, and PRs not targeting the default branch. Groups
# results by repository.
#
# Usage: gh-reviews [--browse]
#   --browse  Open all listed PRs in the browser.

set -euo pipefail

open_in_browser=false
if [ "${1:-}" = "--browse" ]; then
  open_in_browser=true
fi

# Fetch open PRs requesting the user's review, excluding drafts. The `reviews`
# subquery fetches the user's last review to filter out already-approved PRs.
# `baseRefName` and `defaultBranchRef` are compared to only keep PRs targeting
# the default branch.
graphql_query="
  query {
    search(query: \"is:open is:pr review-requested:@me draft:false\", type: ISSUE, first: 50) {
      nodes {
        ... on PullRequest {
          number
          title
          url
          baseRefName
          author { login }
          repository { nameWithOwner defaultBranchRef { name } }
          reviews(author: \"$(gh api user --jq .login)\", last: 1, states: [APPROVED]) {
            totalCount
          }
        }
      }
    }
  }
"

# Filter out approved PRs and PRs not targeting the default branch, then group
# by repository.
#
# shellcheck disable=SC2016
jq_filter='
  [.data.search.nodes[]
    | select(.reviews.totalCount == 0)
    | select(.baseRefName == .repository.defaultBranchRef.name)
  ]
  | group_by(.repository.nameWithOwner)
  | .[]
  | (.[0].repository.nameWithOwner) as $repository
  | $repository,
    (.[] | [(.number | tostring), .title, .url, (.author.login // "unknown")] | @tsv)
'

api_response=$(gh api graphql --field query="${graphql_query}" | jq --raw-output "${jq_filter}")

while IFS=$'\t' read -r number title url author; do
  if [ -z "${title}" ]; then
    # Lines without a tab are repository headers.
    echo "${number}"
  else
    # OSC 8 hyperlink: make the title clickable in supported terminals.
    # Format: ESC]8;;<url>ESC\<text>ESC]8;;ESC\
    printf '  • \033]8;;%s\033\\#%s %s\033]8;;\033\\ by %s\n' \
      "${url}" "${number}" "${title}" "${author}"

    if [ "${open_in_browser}" = true ]; then
      open "${url}"
    fi
  fi
done <<< "${api_response}"
